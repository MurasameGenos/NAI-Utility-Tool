<Window
    x:Class="NAITool.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:canvas="using:Microsoft.Graphics.Canvas.UI.Xaml"
    xmlns:controls="using:NAITool.Controls"
    xmlns:local="using:NAITool"
    Title="NAI Utility Tool">

    <Grid x:Name="RootGrid"
          AllowDrop="False"
          DragEnter="OnSuperDropDragEnter"
          DragOver="OnSuperDropDragOver"
          DragLeave="OnSuperDropDragLeave"
          Drop="OnSuperDropRootDrop">
        <Grid.Resources>
            <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <LinearGradientBrush x:Key="HistoryThumbnailGlassOverlayBrush" StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#66FFFFFF" Offset="0"/>
                        <GradientStop Color="#26FFFFFF" Offset="0.42"/>
                        <GradientStop Color="#10FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                    <LinearGradientBrush x:Key="HistoryThumbnailGlassBorderBrush" StartPoint="0.15,0" EndPoint="0.85,1">
                        <GradientStop Color="#C2D0DAE2" Offset="0"/>
                        <GradientStop Color="#7EBDC8D1" Offset="0.45"/>
                        <GradientStop Color="#4C98A6B0" Offset="1"/>
                    </LinearGradientBrush>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <LinearGradientBrush x:Key="HistoryThumbnailGlassOverlayBrush" StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1AFFFFFF" Offset="0"/>
                        <GradientStop Color="#0AFFFFFF" Offset="0.42"/>
                        <GradientStop Color="#03FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                    <LinearGradientBrush x:Key="HistoryThumbnailGlassBorderBrush" StartPoint="0.15,0" EndPoint="0.85,1">
                        <GradientStop Color="#44FFFFFF" Offset="0"/>
                        <GradientStop Color="#1FFFFFFF" Offset="0.45"/>
                        <GradientStop Color="#0EFFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Default">
                    <LinearGradientBrush x:Key="HistoryThumbnailGlassOverlayBrush" StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#66FFFFFF" Offset="0"/>
                        <GradientStop Color="#26FFFFFF" Offset="0.42"/>
                        <GradientStop Color="#10FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                    <LinearGradientBrush x:Key="HistoryThumbnailGlassBorderBrush" StartPoint="0.15,0" EndPoint="0.85,1">
                        <GradientStop Color="#C2D0DAE2" Offset="0"/>
                        <GradientStop Color="#7EBDC8D1" Offset="0.45"/>
                        <GradientStop Color="#4C98A6B0" Offset="1"/>
                    </LinearGradientBrush>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
            <Style x:Key="InspectCaptionStyle" TargetType="TextBlock" BasedOn="{StaticResource CaptionTextBlockStyle}">
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}"/>
            </Style>
            <Style x:Key="InspectSubLabelStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="Margin" Value="0,4,0,0"/>
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorTertiaryBrush}"/>
            </Style>
            <LinearGradientBrush x:Key="SuperDropGlassBackground" StartPoint="0.6,0" EndPoint="0.4,1">
                <GradientStop Color="#1AFFFFFF" Offset="0.0"/>
                <GradientStop Color="#0AFFFFFF" Offset="1.0"/>
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="SuperDropGlassBorder" StartPoint="0.6,0" EndPoint="0.4,1">
                <GradientStop Color="#4DFFFFFF" Offset="0.0"/>
                <GradientStop Color="#26FFFFFF" Offset="0.5"/>
                <GradientStop Color="#1AFFFFFF" Offset="1.0"/>
            </LinearGradientBrush>
            <Style x:Key="SuperDropCardStyle" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource SuperDropGlassBackground}"/>
                <Setter Property="BorderBrush" Value="{StaticResource SuperDropGlassBorder}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="16"/>
                <Setter Property="Padding" Value="0"/>
            </Style>
            <Style x:Key="SuperDropCardTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="FontWeight" Value="Normal"/>
                <Setter Property="TextAlignment" Value="Center"/>
                <Setter Property="TextWrapping" Value="WrapWholeWords"/>
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}"/>
            </Style>
            <Style x:Key="SuperDropCardIconStyle" TargetType="FontIcon">
                <Setter Property="FontFamily" Value="{StaticResource SymbolThemeFontFamily}"/>
                <Setter Property="FontSize" Value="36"/>
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}"/>
                <Setter Property="Margin" Value="0,0,0,12"/>
            </Style>
            <DataTemplate x:Key="HistorySeparatorTemplate" x:DataType="local:HistoryListItem">
                <Grid Margin="8,10,8,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            Height="1"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            Background="Gray"
                            Opacity="0.4"/>
                    <TextBlock Grid.Column="1"
                               Text="{x:Bind DateLabel}"
                               FontSize="12"
                               Foreground="Gray"/>
                    <Border Grid.Column="2"
                            Height="1"
                            Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            Background="Gray"
                            Opacity="0.4"/>
                </Grid>
            </DataTemplate>
            <DataTemplate x:Key="HistoryThumbnailTemplate" x:DataType="local:HistoryListItem">
                <Border x:Name="HistoryThumbnailHost"
                        Background="Transparent"
                        CornerRadius="4"
                        Padding="2"
                        Margin="8,0,8,0"
                        Tag="{x:Bind FilePath, Mode=OneWay}"
                        PointerPressed="OnHistoryItemClick"
                        Loaded="OnHistoryThumbnailHostLoaded"
                        DataContextChanged="OnHistoryThumbnailHostDataContextChanged">
                    <Grid HorizontalAlignment="Center">
                        <Border x:Name="HistoryThumbnailPlaceholder"
                                Width="{x:Bind ThumbnailWidth, Mode=OneWay}"
                                Height="{x:Bind ThumbnailHeight, Mode=OneWay}"
                                CornerRadius="8"
                                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                HorizontalAlignment="Center">
                            <Grid>
                                <Border Background="{StaticResource HistoryThumbnailGlassOverlayBrush}"
                                        CornerRadius="8"
                                        IsHitTestVisible="False"/>
                                <Border CornerRadius="8"
                                        BorderBrush="{StaticResource HistoryThumbnailGlassBorderBrush}"
                                        BorderThickness="1"
                                        Background="Transparent"
                                        IsHitTestVisible="False"/>
                                <ProgressRing IsActive="True"
                                              Width="28"
                                              Height="28"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <Image x:Name="HistoryThumbnailImage"
                               Width="{x:Bind ThumbnailWidth, Mode=OneWay}"
                               Height="{x:Bind ThumbnailHeight, Mode=OneWay}"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               Loaded="OnHistoryThumbnailImageLoaded"
                               Unloaded="OnHistoryThumbnailImageUnloaded"
                               DataContextChanged="OnHistoryThumbnailImageDataContextChanged"/>
                    </Grid>
                </Border>
            </DataTemplate>
            <local:HistoryItemTemplateSelector x:Key="HistoryTemplateSelector"
                                               SeparatorTemplate="{StaticResource HistorySeparatorTemplate}"
                                               ThumbnailTemplate="{StaticResource HistoryThumbnailTemplate}"/>
            </ResourceDictionary>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ════════════ 自定义标题栏 ════════════ -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" VerticalAlignment="Stretch"
              Background="Transparent"
              DoubleTapped="OnAppTitleBarDoubleTapped">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="AppTitleText" Grid.Column="0" Text="NAI Utility Tool"
                       FontSize="14" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="16,0,16,0"
                       IsHitTestVisible="False"/>

            <MenuBar x:Name="AppMenuBar" Grid.Column="1" VerticalAlignment="Center">
                <MenuBarItem x:Name="MenuFile" Title="">
                    <MenuFlyoutItem x:Name="MenuOpenImage" Text="" Click="OnOpenImage">
                        <MenuFlyoutItem.Icon><SymbolIcon Symbol="OpenFile"/></MenuFlyoutItem.Icon>
                        <MenuFlyoutItem.KeyboardAccelerators>
                            <KeyboardAccelerator Modifiers="Control" Key="O"/>
                        </MenuFlyoutItem.KeyboardAccelerators>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem x:Name="MenuSave" Text="" Click="OnSaveOverwrite">
                        <MenuFlyoutItem.Icon>
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE74E;"/>
                        </MenuFlyoutItem.Icon>
                        <MenuFlyoutItem.KeyboardAccelerators>
                            <KeyboardAccelerator Modifiers="Control" Key="S"/>
                        </MenuFlyoutItem.KeyboardAccelerators>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem x:Name="MenuSaveAs" Text="" Click="OnSaveAs">
                        <MenuFlyoutItem.Icon>
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE792;"/>
                        </MenuFlyoutItem.Icon>
                        <MenuFlyoutItem.KeyboardAccelerators>
                            <KeyboardAccelerator Modifiers="Control,Shift" Key="S"/>
                        </MenuFlyoutItem.KeyboardAccelerators>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem x:Name="MenuSaveStripped" Text=""
                                    Click="OnSaveAsStripped" Visibility="Collapsed">
                        <MenuFlyoutItem.Icon>
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE792;"/>
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem x:Name="MenuExportCanvasMask" Text=""
                                    Click="OnExportCanvasMask" Visibility="Collapsed">
                        <MenuFlyoutItem.Icon>
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE72D;"/>
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem x:Name="MenuOpenImageFolder" Text="" Click="OnOpenImageFolder">
                        <MenuFlyoutItem.Icon>
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xED25;"/>
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutSeparator/>
                    <MenuFlyoutItem x:Name="MenuExit" Text="" Click="OnExit">
                        <MenuFlyoutItem.Icon>
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xF3B1;"/>
                        </MenuFlyoutItem.Icon>
                        <MenuFlyoutItem.KeyboardAccelerators>
                            <KeyboardAccelerator Modifiers="Menu" Key="F4"/>
                        </MenuFlyoutItem.KeyboardAccelerators>
                    </MenuFlyoutItem>
                </MenuBarItem>

                <MenuBarItem x:Name="MenuEdit" Title=""/>
                <MenuBarItem x:Name="MenuTools" Title=""/>

                <MenuBarItem x:Name="MenuView" Title="">
                    <MenuFlyoutItem x:Name="MenuFitToScreen" Text="" Click="OnFitToScreen">
                        <MenuFlyoutItem.Icon>
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE9A6;"/>
                        </MenuFlyoutItem.Icon>
                        <MenuFlyoutItem.KeyboardAccelerators>
                            <KeyboardAccelerator Modifiers="Control" Key="Number0"/>
                        </MenuFlyoutItem.KeyboardAccelerators>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem x:Name="MenuActualSize" Text="" Click="OnActualSize">
                        <MenuFlyoutItem.Icon>
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE7F9;"/>
                        </MenuFlyoutItem.Icon>
                        <MenuFlyoutItem.KeyboardAccelerators>
                            <KeyboardAccelerator Modifiers="Control" Key="Number1"/>
                        </MenuFlyoutItem.KeyboardAccelerators>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem x:Name="MenuCenterView" Text="" Click="OnCenterView">
                        <MenuFlyoutItem.Icon>
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE799;"/>
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutSeparator/>
                    <MenuFlyoutItem x:Name="MenuZoomIn" Text="" Click="OnZoomIn">
                        <MenuFlyoutItem.Icon><SymbolIcon Symbol="ZoomIn"/></MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem x:Name="MenuZoomOut" Text="" Click="OnZoomOut">
                        <MenuFlyoutItem.Icon><SymbolIcon Symbol="ZoomOut"/></MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                </MenuBarItem>

                <MenuBarItem x:Name="MenuSettings" Title="">
                    <MenuFlyoutItem x:Name="MenuQuickTour" Text="" Click="OnQuickTour">
                        <MenuFlyoutItem.Icon>
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xEA5E;"/>
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutSeparator/>
                    <MenuFlyoutItem x:Name="MenuUsageSettings" Text="" Click="OnUsageSettings">
                        <MenuFlyoutItem.Icon>
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE713;"/>
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutSeparator/>
                    <MenuFlyoutItem x:Name="MenuQuotaSettings" Text="" Click="OnQuotaSettings">
                        <MenuFlyoutItem.Icon>
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xF159;"/>
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem x:Name="MenuReverseTaggerSettings" Text="" Click="OnReverseTaggerSettings">
                        <MenuFlyoutItem.Icon>
                            <SymbolIcon Symbol="Tag"/>
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem x:Name="MenuNetworkSettings" Text="" Click="OnNetworkSettings" Visibility="Collapsed">
                        <MenuFlyoutItem.Icon><SymbolIcon Symbol="Globe"/></MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem x:Name="MenuPerformanceSettings" Text="" Click="OnPerformanceSettings" Visibility="Collapsed">
                        <MenuFlyoutItem.Icon>
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE9D9;"/>
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutSubItem x:Name="MenuAppearance" Text="" Visibility="Collapsed">
                        <MenuFlyoutSubItem.Icon>
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE790;"/>
                        </MenuFlyoutSubItem.Icon>
                        <ToggleMenuFlyoutItem x:Name="MenuThemeSystem" Text=""
                                              IsChecked="True" Click="OnThemeChanged" Tag="System">
                            <ToggleMenuFlyoutItem.Icon>
                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xEC76;"/>
                            </ToggleMenuFlyoutItem.Icon>
                        </ToggleMenuFlyoutItem>
                        <ToggleMenuFlyoutItem x:Name="MenuThemeLight" Text=""
                                              Click="OnThemeChanged" Tag="Light">
                            <ToggleMenuFlyoutItem.Icon>
                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE706;"/>
                            </ToggleMenuFlyoutItem.Icon>
                        </ToggleMenuFlyoutItem>
                        <ToggleMenuFlyoutItem x:Name="MenuThemeDark" Text=""
                                              Click="OnThemeChanged" Tag="Dark">
                            <ToggleMenuFlyoutItem.Icon>
                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE708;"/>
                            </ToggleMenuFlyoutItem.Icon>
                        </ToggleMenuFlyoutItem>
                        <MenuFlyoutSeparator/>
                        <ToggleMenuFlyoutItem x:Name="MenuTransparencyStandard" Text=""
                                              IsChecked="True" Click="OnTransparencyChanged" Tag="Standard">
                            <ToggleMenuFlyoutItem.Icon>
                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE904;"/>
                            </ToggleMenuFlyoutItem.Icon>
                        </ToggleMenuFlyoutItem>
                        <ToggleMenuFlyoutItem x:Name="MenuTransparencyLesser" Text=""
                                              Click="OnTransparencyChanged" Tag="Lesser">
                            <ToggleMenuFlyoutItem.Icon>
                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE906;"/>
                            </ToggleMenuFlyoutItem.Icon>
                        </ToggleMenuFlyoutItem>
                        <ToggleMenuFlyoutItem x:Name="MenuTransparencyOpaque" Text=""
                                              Click="OnTransparencyChanged" Tag="Opaque">
                            <ToggleMenuFlyoutItem.Icon>
                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE908;"/>
                            </ToggleMenuFlyoutItem.Icon>
                        </ToggleMenuFlyoutItem>
                    </MenuFlyoutSubItem>
                    <MenuFlyoutSubItem x:Name="MenuLanguage" Text="" Visibility="Collapsed">
                        <MenuFlyoutSubItem.Icon>
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xF2B7;"/>
                        </MenuFlyoutSubItem.Icon>
                        <ToggleMenuFlyoutItem x:Name="MenuLanguageEnglish" Text="English"
                                              Click="OnLanguageChanged" Tag="en_us"/>
                        <ToggleMenuFlyoutItem x:Name="MenuLanguageZhCn" Text=""
                                              Click="OnLanguageChanged" Tag="zh_cn"/>
                        <ToggleMenuFlyoutItem x:Name="MenuLanguageZhTw" Text=""
                                              Click="OnLanguageChanged" Tag="zh_tw"/>
                        <ToggleMenuFlyoutItem x:Name="MenuLanguageJaJp" Text=""
                                              Click="OnLanguageChanged" Tag="ja_jp"/>
                    </MenuFlyoutSubItem>
                    <MenuFlyoutItem x:Name="MenuDevSettings" Text="" Click="OnDevSettings" Visibility="Collapsed">
                        <MenuFlyoutItem.Icon>
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xEC7A;"/>
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                </MenuBarItem>

                <MenuBarItem x:Name="MenuHelp" Title="">
                    <MenuFlyoutItem x:Name="MenuHelpOverview" Text="" Click="OnHelpOverview">
                        <MenuFlyoutItem.Icon>
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE897;"/>
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem x:Name="MenuHelpHighlights" Text="" Click="OnHelpHighlights">
                        <MenuFlyoutItem.Icon>
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE734;"/>
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutSeparator/>
                    <MenuFlyoutItem x:Name="MenuHelpLinks" Text="" Click="OnHelpUsefulLinks">
                        <MenuFlyoutItem.Icon>
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE71B;"/>
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem x:Name="MenuAbout" Text="" Click="OnAbout">
                        <MenuFlyoutItem.Icon>
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE946;"/>
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                </MenuBarItem>
            </MenuBar>

            <!-- 模式切换 Tab -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center"
                        Margin="16,0,0,0">
                <ToggleButton x:Name="TabGenerate" Content="" IsChecked="True"
                              Click="OnModeTabSwitch" CornerRadius="4,0,0,4"
                              MinWidth="56" Height="34"/>
                <ToggleButton x:Name="TabI2I" Content=""
                              Click="OnModeTabSwitch" CornerRadius="0"
                              MinWidth="56" Height="34"/>
                <ToggleButton x:Name="TabUpscale" Content=""
                              Click="OnModeTabSwitch" CornerRadius="0"
                              MinWidth="56" Height="34"/>
                <ToggleButton x:Name="TabEffects" Content=""
                              Click="OnModeTabSwitch" CornerRadius="0"
                              MinWidth="56" Height="34"/>
                <ToggleButton x:Name="TabInspect" Content=""
                              Click="OnModeTabSwitch" CornerRadius="0,4,4,0"
                              MinWidth="56" Height="34"/>
            </StackPanel>
        </Grid>

        <!-- ════════════ 主内容 ════════════ -->
        <Grid x:Name="MainContentGrid" Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="260"/>
            </Grid.ColumnDefinitions>

            <!-- ═══ 左侧栏（生图/重绘） ═══ -->
            <Border x:Name="PanelLeftMain" Grid.Column="0"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer x:Name="LeftPanelScrollViewer" Grid.Row="0"
                                  VerticalScrollBarVisibility="Auto"
                                  SizeChanged="OnLeftPanelScrollViewerSizeChanged">
                        <Grid Padding="12" RowSpacing="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel x:Name="ModelHeaderPanel" Grid.Row="0" Spacing="4">
                                <Grid>
                                    <TextBlock x:Name="TxtModelLabel" Text=""
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TxtAnlasBalance"
                                               Text="Anlas: --"
                                               Visibility="Collapsed"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </Grid>
                                <ComboBox x:Name="CboModel"
                                          HorizontalAlignment="Stretch"/>
                            </StackPanel>

                            <Grid x:Name="PromptTabRow" Grid.Row="1" ColumnSpacing="8"
                                  SizeChanged="OnPromptTabRowSizeChanged">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <ToggleButton x:Name="TabPositive" Content=""
                                                  Grid.Column="0"
                                                  IsChecked="True" Click="OnPromptTabSwitch"
                                                  HorizontalAlignment="Stretch"
                                                  HorizontalContentAlignment="Center"
                                                  Height="34"
                                                  MinWidth="0"
                                                  CornerRadius="4,0,0,4"/>
                                    <ToggleButton x:Name="TabNegative" Content=""
                                                  Grid.Column="1"
                                                  Click="OnPromptTabSwitch"
                                                  HorizontalAlignment="Stretch"
                                                  HorizontalContentAlignment="Center"
                                                  Height="34"
                                                  MinWidth="0"
                                                  CornerRadius="0,4,4,0"/>
                                </Grid>
                                <ToggleButton x:Name="BtnSplitPrompt" Grid.Column="1"
                                              HorizontalAlignment="Right"
                                              Click="OnSplitPromptToggle"
                                              ToolTipService.ToolTip=""
                                              Width="34" Height="34" Padding="0">
                                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}"
                                              Glyph="&#xE737;" FontSize="14"/>
                                </ToggleButton>
                            </Grid>

                            <Grid x:Name="PromptAreaGrid" Grid.Row="2" MinHeight="80" RowSpacing="6">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Visibility="Collapsed"
                                      x:Name="StylePromptGrid">
                                    <controls:PromptTextBox x:Name="TxtStylePrompt"
                                                            Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                            AcceptsReturn="True" TextWrapping="Wrap"
                                                            IsSpellCheckEnabled="False"
                                                            PlaceholderText=""
                                                            MinHeight="34" MaxHeight="120"
                                                            TextChanged="OnStylePromptTextChanged"
                                                            SelectionChanged="OnPromptSelectionChanged"
                                                            SizeChanged="OnStylePromptSizeChanged"
                                                            PreviewKeyDown="OnPromptPreviewKeyDown"
                                                            KeyDown="OnPromptKeyDown"
                                                            LostFocus="OnPromptLostFocus"/>
                                </Grid>

                                <Grid Grid.Row="1">
                                    <controls:PromptTextBox x:Name="TxtPrompt"
                                                            Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                            AcceptsReturn="True"
                                                            TextWrapping="Wrap"
                                                            IsSpellCheckEnabled="False"
                                                            PlaceholderText=""
                                                            PreviewKeyDown="OnPromptPreviewKeyDown"
                                                            KeyDown="OnPromptKeyDown"
                                                            TextChanged="OnPromptTextChanged"
                                                            SelectionChanged="OnPromptSelectionChanged"
                                                            SizeChanged="OnPromptSizeChanged"
                                                            LostFocus="OnPromptLostFocus"/>
                                </Grid>
                            </Grid>

                            <!-- 自动补全弹出框 -->
                            <Popup x:Name="AutoCompletePopup"
                                   IsLightDismissEnabled="False">
                                <Border CornerRadius="6"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        Width="240" MaxHeight="260">
                                    <Border.Background>
                                        <AcrylicBrush TintColor="{ThemeResource SolidBackgroundFillColorBase}"
                                                      TintOpacity="0.25"
                                                      FallbackColor="{ThemeResource SolidBackgroundFillColorBase}"/>
                                    </Border.Background>
                                    <ListView x:Name="AutoCompleteList"
                                              SelectionMode="Single"
                                              IsItemClickEnabled="True"
                                              ItemClick="OnAutoCompleteItemClick"
                                              IsTabStop="False"
                                              Background="Transparent"
                                              Padding="0" Margin="0">
                                        <ListView.ItemContainerTransitions>
                                            <TransitionCollection/>
                                        </ListView.ItemContainerTransitions>
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Padding="6,4" ColumnSpacing="8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Ellipse Grid.Column="0" Width="8" Height="8"
                                                             VerticalAlignment="Center"
                                                             Fill="{Binding CategoryBrush}"/>
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding TagName}"
                                                                   FontWeight="SemiBold" FontSize="13"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding AliasText}"
                                                                   FontSize="11"
                                                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                                   Visibility="{Binding AliasVisibility}"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="2" Text="{Binding CountText}"
                                                               FontSize="11" VerticalAlignment="Center"
                                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </Border>
                            </Popup>

                            <StackPanel x:Name="BottomContentPanel" Grid.Row="3" Spacing="10"
                                        SizeChanged="OnBottomContentPanelSizeChanged">

                            <StackPanel x:Name="CharacterPanel" Spacing="6"
                                        Visibility="Collapsed">
                                <StackPanel x:Name="CharacterContainer" Spacing="6"/>
                            </StackPanel>

                            <StackPanel x:Name="VibeTransferPanel" Spacing="6"
                                        Visibility="Collapsed">
                                <TextBlock x:Name="TxtVibeTransferHint"
                                           Visibility="Collapsed"
                                           TextWrapping="Wrap"
                                           FontSize="11"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <StackPanel x:Name="VibeTransferContainer" Spacing="6"/>
                            </StackPanel>

                            <StackPanel x:Name="PreciseReferencePanel" Spacing="6"
                                        Visibility="Collapsed">
                                <TextBlock x:Name="TxtPreciseReferenceHint"
                                           Visibility="Collapsed"
                                           TextWrapping="Wrap"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <StackPanel x:Name="PreciseReferenceContainer" Spacing="6"/>
                            </StackPanel>

                            <Grid x:Name="ReferenceButtonRow" ColumnSpacing="6"
                                  Visibility="Collapsed"
                                  SizeChanged="OnReferenceButtonRowSizeChanged">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition x:Name="ReferenceButtonCol0" Width="*"/>
                                    <ColumnDefinition x:Name="ReferenceButtonCol1" Width="*"/>
                                    <ColumnDefinition x:Name="ReferenceButtonCol2" Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button x:Name="BtnAddCharacter" Click="OnAddCharacter"
                                        Height="34"
                                        Padding="8,0"
                                        HorizontalAlignment="Stretch"
                                        Background="Transparent"
                                        BorderThickness="1"
                                        BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                        Visibility="Collapsed">
                                    <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <FontIcon x:Name="IconAddCharacter"
                                                  FontFamily="{StaticResource SymbolThemeFontFamily}"
                                                  Glyph="&#xE77B;"
                                                  FontSize="11"
                                                  VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TxtAddCharacterButton"
                                            Text=""
                                                   FontSize="12"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button x:Name="BtnAddVibeTransfer" Click="OnAddVibeTransfer"
                                        Height="34"
                                        Padding="8,0"
                                        HorizontalAlignment="Stretch"
                                        Background="Transparent"
                                        BorderThickness="1"
                                        BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                        Visibility="Collapsed">
                                    <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <FontIcon x:Name="IconAddVibeTransfer"
                                                  FontFamily="{StaticResource SymbolThemeFontFamily}"
                                                  Glyph="&#xEB9F;"
                                                  FontSize="11"
                                                  VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TxtAddVibeTransferButton"
                                            Text=""
                                                   FontSize="12"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button x:Name="BtnAddPreciseReference" Click="OnAddPreciseReference"
                                        Height="34"
                                        Padding="8,0"
                                        HorizontalAlignment="Stretch"
                                        Background="Transparent"
                                        BorderThickness="1"
                                        BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                        Visibility="Collapsed">
                                    <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <FontIcon x:Name="IconAddPreciseReference"
                                                  FontFamily="{StaticResource SymbolThemeFontFamily}"
                                                  Glyph="&#xEBD2;"
                                                  FontSize="11"
                                                  VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TxtAddPreciseReferenceButton"
                                            Text=""
                                                   FontSize="12"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <StackPanel Spacing="4">
                            <TextBlock x:Name="TxtSizeLabel" Text=""
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <Grid x:Name="MaxSizePanel" Visibility="Collapsed">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox x:Name="CboSize"
                                              HorizontalAlignment="Stretch"
                                              Visibility="Collapsed"/>
                                    <NumberBox x:Name="NbMaxWidth" Grid.Column="0"
                                               Minimum="64" Maximum="2048" Value="832"
                                               SmallChange="64" LargeChange="64"
                                               SpinButtonPlacementMode="Compact"
                                               ValueChanged="OnMaxSizeValueChanged"/>
                                    <Button x:Name="BtnSwapSizeDimensions" Grid.Column="1" Click="OnSwapSizeDimensions"
                                            MinWidth="32" Height="32" Padding="0"
                                            Background="Transparent" BorderThickness="0"
                                        ToolTipService.ToolTip="">
                                        <TextBlock Text="×" VerticalAlignment="Center"/>
                                    </Button>
                                    <NumberBox x:Name="NbMaxHeight" Grid.Column="3"
                                               Minimum="64" Maximum="2048" Value="1216"
                                               SmallChange="64" LargeChange="64"
                                               SpinButtonPlacementMode="Compact"
                                               ValueChanged="OnMaxSizeValueChanged"/>
                                </Grid>
                            </StackPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <NumberBox x:Name="NbSeed"
                                           Grid.Column="0"
                                           Minimum="0" Value="0"
                                           SpinButtonPlacementMode="Compact">
                                    <NumberBox.Header>
                            <TextBlock x:Name="TxtSeedLabel" Text=""
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </NumberBox.Header>
                                </NumberBox>
                                <Button x:Name="BtnSeedRandomize" Grid.Column="1" Click="OnSeedRandomize"
                                    ToolTipService.ToolTip=""
                                        VerticalAlignment="Bottom" Width="32" Height="32"
                                        Padding="0" Margin="4,0,0,0">
                                    <SymbolIcon Symbol="Shuffle"/>
                                </Button>
                                <Button x:Name="BtnSeedRestore" Grid.Column="2" Click="OnSeedRestore"
                                    ToolTipService.ToolTip=""
                                        VerticalAlignment="Bottom" Width="32" Height="32"
                                        Padding="0" Margin="2,0,0,0">
                                    <SymbolIcon Symbol="Undo"/>
                                </Button>
                            </Grid>

                            <CheckBox x:Name="ChkVariety"
                                      Content=""
                                      VerticalContentAlignment="Center"/>

                            <Button x:Name="BtnAdvancedParams" Click="OnAdvancedParams"
                                    HorizontalAlignment="Stretch">
                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                    <SymbolIcon Symbol="Setting" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtAdvancedParamsButton" Text="" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>

                    <Border Grid.Row="1" Padding="12,8"
                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                            BorderThickness="0,1,0,0">
                        <Button x:Name="BtnGenerate" Click="OnGenerate"
                                HorizontalAlignment="Stretch"
                                Height="40"
                                MinHeight="40"
                                Style="{StaticResource AccentButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <SymbolIcon Symbol="Send" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtGenerateButton" Text="" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Border>
                </Grid>
            </Border>

            <!-- ═══ 左侧栏（检视） ═══ -->
            <Border x:Name="PanelLeftInspect" Grid.Column="0" Visibility="Collapsed"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                        <StackPanel Padding="12" Spacing="10">
                            <TextBlock x:Name="InspectPlaceholder"
                          Text=""
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                       TextWrapping="Wrap"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       Margin="0,20,0,0"/>

                            <TextBox x:Name="TxtInspectRawMeta" Visibility="Collapsed"
                                     IsReadOnly="True" AcceptsReturn="True"
                                     TextWrapping="Wrap" FontFamily="Consolas" FontSize="11"
                                     MaxHeight="500"/>

                            <StackPanel x:Name="InspectContent" Visibility="Collapsed" Spacing="10">
                        <TextBlock x:Name="TxtInspectPositiveLabel" Text=""
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Style="{StaticResource CaptionTextBlockStyle}"/>
                                <TextBox x:Name="TxtInspectPositive" IsReadOnly="True"
                                         AcceptsReturn="True" TextWrapping="Wrap"
                                         MaxHeight="160"/>

                                <StackPanel x:Name="InspectCharPanel" Spacing="4" Visibility="Collapsed"/>

                        <TextBlock x:Name="TxtInspectNegativeLabel" Text=""
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Style="{StaticResource CaptionTextBlockStyle}"/>
                                <TextBox x:Name="TxtInspectNegative" IsReadOnly="True"
                                         AcceptsReturn="True" TextWrapping="Wrap"
                                         MaxHeight="120"/>

                                <StackPanel x:Name="InspectCharNegPanel" Spacing="4" Visibility="Collapsed"/>

                        <TextBlock x:Name="TxtInspectParametersLabel" Text=""
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Style="{StaticResource CaptionTextBlockStyle}" Margin="0,4,0,0"/>
                                <Grid RowSpacing="6" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                <TextBlock x:Name="TxtInspectSizeLabel" Grid.Row="0" Grid.Column="0" Text=""
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="TxtInspectSize"/>

                                <TextBlock x:Name="TxtInspectStepsLabel" Grid.Row="1" Grid.Column="0" Text=""
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="TxtInspectSteps"/>

                                <TextBlock x:Name="TxtInspectSamplerLabel" Grid.Row="2" Grid.Column="0" Text=""
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="TxtInspectSampler"/>

                                <TextBlock x:Name="TxtInspectScheduleLabel" Grid.Row="3" Grid.Column="0" Text=""
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="TxtInspectSchedule"/>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="CFG Scale"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" x:Name="TxtInspectScale"/>

                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="CFG Rescale"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                    <TextBlock Grid.Row="5" Grid.Column="1" x:Name="TxtInspectCfgRescale"/>

                                <TextBlock x:Name="TxtInspectSeedLabel" Grid.Row="6" Grid.Column="0" Text=""
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                    <TextBlock Grid.Row="6" Grid.Column="1" x:Name="TxtInspectSeed"
                                               IsTextSelectionEnabled="True"/>

                                    <TextBlock Grid.Row="7" Grid.Column="0" Text="Variety+"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                    <TextBlock Grid.Row="7" Grid.Column="1" x:Name="TxtInspectVariety"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="1" Padding="12,8"
                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                            BorderThickness="0,1,0,0">
                        <StackPanel Spacing="6">
                            <Button x:Name="BtnSendToGen" Click="OnSendMetadataToGen"
                                    IsEnabled="False"
                                    HorizontalAlignment="Stretch"
                                    Style="{StaticResource AccentButtonStyle}">
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <SymbolIcon x:Name="BtnSendToGenIcon" Symbol="Send" VerticalAlignment="Center"/>
                                <TextBlock x:Name="BtnSendToGenText" Text="" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="BtnSendInspectToI2I" Click="OnSendInspectToI2I"
                                    IsEnabled="False"
                                HorizontalAlignment="Stretch"
                                Style="{StaticResource AccentButtonStyle}">
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE8B9;" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtSendInspectToI2I" Text="" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- ═══ 左侧栏（效果） ═══ -->
            <Border x:Name="PanelLeftEffects" Grid.Column="0" Visibility="Collapsed"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="EffectsPanel" Padding="12" Spacing="10"/>
                </ScrollViewer>
            </Border>

            <!-- ═══ 左侧栏（超分） ═══ -->
            <Border x:Name="PanelLeftUpscale" Grid.Column="0" Visibility="Collapsed"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                        <StackPanel Padding="12" Spacing="10">
                        <TextBlock x:Name="TxtUpscaleModelLabel" Text=""
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <ComboBox x:Name="CboUpscaleModel" HorizontalAlignment="Stretch"
                                      SelectionChanged="OnUpscaleModelChanged"/>

                        <TextBlock x:Name="TxtUpscaleScaleLabel" Text=""
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Margin="0,8,0,0"/>
                            <ComboBox x:Name="CboUpscaleScale" HorizontalAlignment="Stretch"
                                      SelectionChanged="OnUpscaleScaleChanged">
                                <ComboBoxItem Content="2x" Tag="2" IsSelected="True"/>
                                <ComboBoxItem Content="3x" Tag="3"/>
                                <ComboBoxItem Content="4x" Tag="4"/>
                            </ComboBox>

                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    CornerRadius="4" Padding="10,8">
                                <StackPanel Spacing="4">
                                    <Grid>
                                <TextBlock x:Name="TxtUpscaleBeforeLabel" Text=""
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock x:Name="TxtUpscaleInputRes" Text="—"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Grid>
                                <TextBlock x:Name="TxtUpscaleAfterLabel" Text=""
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock x:Name="TxtUpscaleOutputRes" Text="—"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <ProgressBar x:Name="UpscaleProgressBar" Visibility="Collapsed"
                                         IsIndeterminate="True"/>
                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="1" Padding="12,8"
                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                            BorderThickness="0,1,0,0">
                        <Button x:Name="BtnStartUpscale" Click="OnStartUpscale"
                                HorizontalAlignment="Stretch"
                                Height="40"
                                MinHeight="40"
                                Style="{StaticResource AccentButtonStyle}"
                                IsEnabled="False">
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xECE9;" FontSize="16" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtStartUpscaleButton" Text="" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Border>
                </Grid>
            </Border>

            <local:ResizeHandle x:Name="LeftSidebarResizeHandle"
                    Grid.Column="1"
                    Background="Transparent"
                    PointerPressed="OnLeftSidebarResizeStart"
                    PointerMoved="OnLeftSidebarResizeMove"
                    PointerReleased="OnLeftSidebarResizeEnd"
                    PointerCanceled="OnLeftSidebarResizeEnd"
                    PointerEntered="OnLeftSidebarHandlePointerEntered"
                    PointerExited="OnLeftSidebarHandlePointerExited"/>

            <!-- ═══ 中间画布区域 ═══ -->
            <Grid x:Name="GenerationPreviewHost" Grid.Column="2">
                <Grid x:Name="GenPreviewArea" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                      AllowDrop="True" DragOver="OnGenPreviewDragOver" Drop="OnGenPreviewDrop">
                    <Grid x:Name="GenerationPreviewPulseHost"
                          IsHitTestVisible="False"
                          Opacity="0"
                          Visibility="Collapsed">
                        <Border x:Name="GenerationPreviewPulseDarkOverlay"
                                Background="#FF000000"
                                Opacity="0"/>
                        <Border x:Name="GenerationPreviewPulseLightOverlay"
                                Background="#FFFFFFFF"
                                Opacity="0"/>
                    </Grid>
                    <TextBlock x:Name="GenPlaceholder"
                               Text=""
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               FontSize="16"/>
                    <ScrollViewer x:Name="GenImageScroller"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  ZoomMode="Enabled" MinZoomFactor="0.1" MaxZoomFactor="5"
                                  HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                        <Image x:Name="GenPreviewImage" Stretch="Uniform"/>
                    </ScrollViewer>
                    <Button x:Name="BtnShowGenResultBar"
                            Click="OnShowGenResultBar"
                            VerticalAlignment="Bottom" HorizontalAlignment="Right"
                            Margin="0,0,12,12"
                            Width="36" Height="36" Padding="0"
                            Visibility="Collapsed"
                            ToolTipService.ToolTip="Show actions">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}"
                                  Glyph="&#xE712;" FontSize="16"/>
                    </Button>
                </Grid>

                <controls:MaskCanvasControl x:Name="MaskCanvas" Visibility="Collapsed"/>

                <!-- 生图浮动操作窗（可拖动） -->
                <Grid x:Name="GenResultBar"
                      VerticalAlignment="Bottom" HorizontalAlignment="Center"
                      Margin="0,0,0,20" Visibility="Collapsed">
                    <Grid.RenderTransform>
                        <TranslateTransform x:Name="GenResultBarTranslate"/>
                    </Grid.RenderTransform>
                    <Border Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
                            CornerRadius="8" Padding="4,10,12,10"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border Background="Transparent" Padding="8,0"
                                    ManipulationMode="TranslateX,TranslateY"
                                    ManipulationDelta="OnGenResultBarDrag">
                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}"
                                          Glyph="&#xE76F;" FontSize="14"
                                          Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                          VerticalAlignment="Center"/>
                            </Border>
                            <Button x:Name="BtnEnhanceGenResult"
                                    Click="OnEnhanceGenResult"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Height="32"/>
                            <Button x:Name="BtnSendGenResult" Height="32">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xEA53;" FontSize="16"/>
                                    <TextBlock x:Name="TxtSendGenResult" Text=""/>
                                </StackPanel>
                                <Button.Flyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem x:Name="MenuSendGenToI2I" Text="" Click="OnSendToI2I">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xEDFB;"/>
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem x:Name="MenuSendGenToUpscale" Text="" Click="OnSendToUpscaleFromGen">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xECE9;"/>
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem x:Name="MenuSendGenToEffects" Text="" Click="OnSendToEffectsFromGen">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xEB3C;"/>
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem x:Name="MenuSendGenToInspect" Text="" Click="OnGenSendToInspect">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xEE6F;"/>
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                    </MenuFlyout>
                                </Button.Flyout>
                            </Button>
                            <Button Click="OnDeleteGenResult" Foreground="#E74856" Height="32">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE74D;" FontSize="16"/>
                                    <TextBlock x:Name="TxtDeleteGenResult" Text=""/>
                                </StackPanel>
                            </Button>
                            <Button Click="OnCloseGenResultBar" Height="32">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE711;" FontSize="16"/>
                                    <TextBlock x:Name="TxtCloseGenResult" Text=""/>
                                </StackPanel>
                            </Button>
                            <ToggleButton x:Name="BtnPinGenResult" Click="OnPinGenResult"
                                          Height="32" Width="32" Padding="0"
                                          ToolTipService.ToolTip="Pin">
                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}"
                                          Glyph="&#xE718;" FontSize="14"/>
                            </ToggleButton>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- 重绘浮动操作窗（可拖动） -->
                <Grid x:Name="ResultActionBar"
                      VerticalAlignment="Bottom" HorizontalAlignment="Center"
                      Margin="0,0,0,20" Visibility="Collapsed">
                    <Grid.RenderTransform>
                        <TranslateTransform x:Name="ResultBarTranslate"/>
                    </Grid.RenderTransform>
                    <Border Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
                            CornerRadius="8" Padding="4,10,16,10"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border Background="Transparent" Padding="8,0"
                                    ManipulationMode="TranslateX,TranslateY"
                                    ManipulationDelta="OnResultBarDrag">
                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}"
                                          Glyph="&#xE76F;" FontSize="14"
                                          Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                          VerticalAlignment="Center"/>
                            </Border>
                            <Button Click="OnApplyResult" Style="{StaticResource AccentButtonStyle}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <SymbolIcon Symbol="Accept"/>
                                    <TextBlock x:Name="TxtApplyResult" Text=""/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="BtnRedoGenerate" Click="OnRedoGenerate" Style="{StaticResource AccentButtonStyle}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <SymbolIcon Symbol="Refresh"/>
                                    <TextBlock x:Name="TxtRedoGenerate" Text=""/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="BtnCompare">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE81D;" FontSize="16"/>
                                    <TextBlock x:Name="TxtCompareResult" Text=""/>
                                </StackPanel>
                            </Button>
                            <Button Click="OnDiscardResult" Foreground="#E74856">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <SymbolIcon Symbol="Cancel"/>
                                    <TextBlock x:Name="TxtDiscardResult" Text=""/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <!-- ═══ 检视模式预览区（跨中间和右侧列） ═══ -->
            <Grid x:Name="InspectPreviewArea" Grid.Column="2" Grid.ColumnSpan="2"
                  Visibility="Collapsed"
                  Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                  AllowDrop="True"
                  DragOver="OnInspectDragOver" Drop="OnInspectDrop">
                <TextBlock x:Name="InspectImagePlaceholder"
                           Text=""
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                           FontSize="16"/>
                <ScrollViewer x:Name="InspectImageScroller"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              ZoomMode="Enabled" MinZoomFactor="0.1" MaxZoomFactor="5"
                              HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <Image x:Name="InspectPreviewImage" Stretch="None"/>
                </ScrollViewer>
            </Grid>

            <!-- ═══ 效果模式预览区（跨中间和右侧列） ═══ -->
            <Grid x:Name="EffectsPreviewArea" Grid.Column="2" Grid.ColumnSpan="2"
                  Visibility="Collapsed"
                  Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                  AllowDrop="True"
                  DragOver="OnEffectsDragOver" Drop="OnEffectsDrop">
                <TextBlock x:Name="EffectsImagePlaceholder"
                           Text=""
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                           FontSize="16"/>
                <ScrollViewer x:Name="EffectsImageScroller"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              ZoomMode="Enabled" MinZoomFactor="0.1" MaxZoomFactor="5"
                              HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <Grid x:Name="EffectsPreviewContent">
                        <Image x:Name="EffectsPreviewImage" Stretch="None"/>
                        <Canvas x:Name="EffectsOverlayCanvas"
                                Background="Transparent"
                                Visibility="Collapsed"
                                PointerPressed="OnEffectsOverlayPointerPressed"
                                PointerMoved="OnEffectsOverlayPointerMoved"
                                PointerReleased="OnEffectsOverlayPointerReleased"
                                PointerCanceled="OnEffectsOverlayPointerReleased"/>
                    </Grid>
                </ScrollViewer>
            </Grid>

            <!-- ═══ 超分模式预览区（跨中间和右侧列） ═══ -->
            <Grid x:Name="UpscalePreviewArea" Grid.Column="2" Grid.ColumnSpan="2"
                  Visibility="Collapsed"
                  Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                  AllowDrop="True"
                  DragOver="OnUpscaleDragOver" Drop="OnUpscaleDrop">
                <TextBlock x:Name="UpscalePlaceholder"
                           Text=""
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                           FontSize="16"/>
                <ScrollViewer x:Name="UpscaleImageScroller"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              ZoomMode="Enabled" MinZoomFactor="0.1" MaxZoomFactor="5"
                              HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <Image x:Name="UpscalePreviewImage" Stretch="None"/>
                </ScrollViewer>
            </Grid>

            <!-- ═══ 右侧栏：生图模式 = 历史记录 ═══ -->
            <Border x:Name="PanelHistory" Grid.Column="3"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="TxtHistoryTitle" Grid.Row="0" Text="" Margin="12,10,12,6"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <CalendarDatePicker x:Name="HistoryDatePicker" Grid.Row="1"
                                        PlaceholderText=""
                                        Margin="8,0,8,6"
                                        HorizontalAlignment="Stretch"
                                        DateChanged="OnHistoryDateChanged"
                                        CalendarViewDayItemChanging="OnHistoryCalendarDayItemChanging"/>
                    <TextBlock x:Name="HistoryEmptyState" Grid.Row="2"
                               Text=""
                               Visibility="Collapsed"
                               Foreground="Gray"
                               HorizontalAlignment="Center"
                               Margin="0,20,0,0"/>
                    <ListView x:Name="HistoryListView" Grid.Row="2"
                              Visibility="Collapsed"
                              SelectionMode="None"
                              IsItemClickEnabled="False"
                              Loaded="OnHistoryListViewLoaded"
                              Unloaded="OnHistoryListViewUnloaded"
                              ItemTemplateSelector="{StaticResource HistoryTemplateSelector}"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              Padding="0,0,0,8">
                        <ListView.ItemContainerTransitions>
                            <TransitionCollection>
                                <AddDeleteThemeTransition/>
                                <ReorderThemeTransition/>
                            </TransitionCollection>
                        </ListView.ItemContainerTransitions>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="MinHeight" Value="0"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                    </ListView>
                </Grid>
            </Border>

            <!-- ═══ 右侧栏：重绘模式 ═══ -->
            <Border x:Name="PanelI2ITools" Grid.Column="3" Visibility="Collapsed"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="1,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Padding="12" Spacing="12">
                        <TextBlock x:Name="TxtI2IPreviewLabel" Text="" Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="4" Height="180"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1">
                            <Grid x:Name="ThumbnailContainer"
                                  PointerPressed="OnThumbnailPointerPressed"
                                  PointerMoved="OnThumbnailPointerMoved"
                                  PointerReleased="OnThumbnailPointerReleased"
                                  Background="Transparent">
                                <canvas:CanvasAnimatedControl x:Name="ThumbnailCanvas" Draw="OnThumbnailCanvasDraw"/>
                            </Grid>
                        </Border>

                        <TextBlock x:Name="TxtZoomInfo" Text=""
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                        <TextBlock x:Name="TxtI2IModeLabel" Text="" Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <StackPanel Orientation="Horizontal" Spacing="0">
                            <ToggleButton x:Name="BtnI2IInpaintMode" IsChecked="True"
                                          Click="OnI2IEditModeSwitch" CornerRadius="4,0,0,4"
                                          MinWidth="84" Height="34"/>
                            <ToggleButton x:Name="BtnI2IDenoiseMode"
                                          Click="OnI2IEditModeSwitch" CornerRadius="0,4,4,0"
                                          MinWidth="84" Height="34"/>
                        </StackPanel>

                        <StackPanel x:Name="PanelI2IInpaintTools" Spacing="12">
                            <CheckBox x:Name="ChkPreviewMask" Content="" VerticalContentAlignment="Center"
                                      Click="OnTogglePreviewMask"/>

                            <TextBlock x:Name="TxtI2IToolsLabel" Text="" Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <ToggleButton x:Name="BtnBrush" IsChecked="True"
                                              Click="OnToolBrush" ToolTipService.ToolTip=""
                                              Width="40" Height="40" Padding="0">
                                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}"
                                              Glyph="&#xEDFB;" FontSize="18"/>
                                </ToggleButton>
                                <ToggleButton x:Name="BtnEraser"
                                              Click="OnToolEraser" ToolTipService.ToolTip=""
                                              Width="40" Height="40" Padding="0">
                                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}"
                                              Glyph="&#xE75C;" FontSize="18"/>
                                </ToggleButton>
                                <ToggleButton x:Name="BtnRect"
                                              Click="OnToolRect" ToolTipService.ToolTip=""
                                              Width="40" Height="40" Padding="0">
                                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}"
                                              Glyph="&#xE739;" FontSize="18"/>
                                </ToggleButton>
                            </StackPanel>

                            <TextBlock x:Name="TxtBrushSizeLabel" Text="" Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="SliderBrushSize" Minimum="1" Maximum="200" Value="20"
                                        Grid.Column="0" VerticalAlignment="Center"
                                        ValueChanged="OnBrushSizeChanged"/>
                                <TextBlock x:Name="TxtBrushSize" Text="20" Grid.Column="1"
                                           FontSize="12" MinWidth="28" TextAlignment="Right"
                                           VerticalAlignment="Center" Margin="8,0,0,0"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </Grid>
                        </StackPanel>

                        <StackPanel x:Name="PanelI2IDenoiseTools" Spacing="12" Visibility="Collapsed">
                            <TextBlock x:Name="TxtDenoiseStrengthLabel" Text="" Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="SliderDenoiseStrength" Minimum="0" Maximum="1" Value="0.7"
                                        StepFrequency="0.01" Grid.Column="0" VerticalAlignment="Center"
                                        ValueChanged="OnDenoiseStrengthChanged"/>
                                <TextBlock x:Name="TxtDenoiseStrength" Text="0.70" Grid.Column="1"
                                           FontSize="12" MinWidth="36" TextAlignment="Right"
                                           VerticalAlignment="Center" Margin="8,0,0,0"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </Grid>

                            <TextBlock x:Name="TxtDenoiseNoiseLabel" Text="" Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="SliderDenoiseNoise" Minimum="0" Maximum="1" Value="0"
                                        StepFrequency="0.01" Grid.Column="0" VerticalAlignment="Center"
                                        ValueChanged="OnDenoiseNoiseChanged"/>
                                <TextBlock x:Name="TxtDenoiseNoise" Text="0.00" Grid.Column="1"
                                           FontSize="12" MinWidth="36" TextAlignment="Right"
                                           VerticalAlignment="Center" Margin="8,0,0,0"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ════════════ 状态栏 ════════════ -->
        <Border Grid.Row="2" Padding="12,4" Height="28"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0">
            <TextBlock x:Name="TxtStatus" Text=""
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextTrimming="CharacterEllipsis"
                       VerticalAlignment="Center"
                       MaxLines="1"/>
        </Border>

        <Grid x:Name="SuperDropOverlay"
              Grid.RowSpan="3"
              Visibility="Collapsed"
              Opacity="0"
              AllowDrop="True"
              DragOver="OnSuperDropDragOver"
              DragLeave="OnSuperDropDragLeave"
              Drop="OnSuperDropRootDrop">
            <Border x:Name="SuperDropBackdropFallback"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
            <Image x:Name="SuperDropBlurredBackdrop"
                   Stretch="Fill"
                   Opacity="0"
                   IsHitTestVisible="False"/>
            <!-- 压暗层：提供统一的 25% 黑色遮罩，确保空白区域和内容区域亮度一致 -->
            <Border Background="#40000000"/>
            
            <Grid x:Name="SuperDropCardsHost"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  MaxWidth="760"
                  MaxHeight="760"
                  Opacity="0"
                  Margin="28"
                  RenderTransformOrigin="0.5,0.5">
                <Grid.RenderTransform>
                    <ScaleTransform x:Name="SuperDropCardsScale" ScaleX="0.96" ScaleY="0.96"/>
                </Grid.RenderTransform>

                <Viewbox
                         Stretch="Uniform"
                         MaxWidth="720"
                         MaxHeight="720">
                    <Grid Width="720" Height="720" RowSpacing="12" ColumnSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource SuperDropCardStyle}" Tag="GeneratePrompt" AllowDrop="True" DragOver="OnSuperDropCardDragOver" DragLeave="OnSuperDropCardDragLeave" Drop="OnSuperDropCardDrop" PointerEntered="OnSuperDropCardPointerEntered" PointerExited="OnSuperDropCardPointerExited">
                            <Grid>
                                <Border Background="{ThemeResource AccentFillColorDefaultBrush}" Opacity="0" CornerRadius="16"/>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="16">
                                    <FontIcon Glyph="&#xE91B;" Style="{StaticResource SuperDropCardIconStyle}"/>
                                    <TextBlock x:Name="TxtSuperDropGeneratePrompt" Style="{StaticResource SuperDropCardTextStyle}" Text=""/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource SuperDropCardStyle}" Tag="GenerateVibe" AllowDrop="True" DragOver="OnSuperDropCardDragOver" DragLeave="OnSuperDropCardDragLeave" Drop="OnSuperDropCardDrop" PointerEntered="OnSuperDropCardPointerEntered" PointerExited="OnSuperDropCardPointerExited">
                            <Grid>
                                <Border Background="{ThemeResource AccentFillColorDefaultBrush}" Opacity="0" CornerRadius="16"/>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="16">
                                    <FontIcon Glyph="&#xEB9F;" Style="{StaticResource SuperDropCardIconStyle}"/>
                                    <TextBlock x:Name="TxtSuperDropGenerateVibe" Style="{StaticResource SuperDropCardTextStyle}" Text=""/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource SuperDropCardStyle}" Tag="GeneratePrecise" AllowDrop="True" DragOver="OnSuperDropCardDragOver" DragLeave="OnSuperDropCardDragLeave" Drop="OnSuperDropCardDrop" PointerEntered="OnSuperDropCardPointerEntered" PointerExited="OnSuperDropCardPointerExited">
                            <Grid>
                                <Border Background="{ThemeResource AccentFillColorDefaultBrush}" Opacity="0" CornerRadius="16"/>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="16">
                                    <FontIcon Glyph="&#xF158;" Style="{StaticResource SuperDropCardIconStyle}"/>
                                    <TextBlock x:Name="TxtSuperDropGeneratePrecise" Style="{StaticResource SuperDropCardTextStyle}" Text=""/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource SuperDropCardStyle}" Tag="I2IPrompt" AllowDrop="True" DragOver="OnSuperDropCardDragOver" DragLeave="OnSuperDropCardDragLeave" Drop="OnSuperDropCardDrop" PointerEntered="OnSuperDropCardPointerEntered" PointerExited="OnSuperDropCardPointerExited">
                            <Grid>
                                <Border Background="{ThemeResource AccentFillColorDefaultBrush}" Opacity="0" CornerRadius="16"/>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="16">
                                    <FontIcon Glyph="&#xEDFB;" Style="{StaticResource SuperDropCardIconStyle}"/>
                                    <TextBlock x:Name="TxtSuperDropI2IPrompt" Style="{StaticResource SuperDropCardTextStyle}" Text=""/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource SuperDropCardStyle}" Tag="I2IVibe" AllowDrop="True" DragOver="OnSuperDropCardDragOver" DragLeave="OnSuperDropCardDragLeave" Drop="OnSuperDropCardDrop" PointerEntered="OnSuperDropCardPointerEntered" PointerExited="OnSuperDropCardPointerExited">
                            <Grid>
                                <Border Background="{ThemeResource AccentFillColorDefaultBrush}" Opacity="0" CornerRadius="16"/>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="16">
                                    <FontIcon Glyph="&#xE771;" Style="{StaticResource SuperDropCardIconStyle}"/>
                                    <TextBlock x:Name="TxtSuperDropI2IVibe" Style="{StaticResource SuperDropCardTextStyle}" Text=""/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource SuperDropCardStyle}" Tag="I2IPrecise" AllowDrop="True" DragOver="OnSuperDropCardDragOver" DragLeave="OnSuperDropCardDragLeave" Drop="OnSuperDropCardDrop" PointerEntered="OnSuperDropCardPointerEntered" PointerExited="OnSuperDropCardPointerExited">
                            <Grid>
                                <Border Background="{ThemeResource AccentFillColorDefaultBrush}" Opacity="0" CornerRadius="16"/>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="16">
                                    <FontIcon Glyph="&#xEBD2;" Style="{StaticResource SuperDropCardIconStyle}"/>
                                    <TextBlock x:Name="TxtSuperDropI2IPrecise" Style="{StaticResource SuperDropCardTextStyle}" Text=""/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource SuperDropCardStyle}" Tag="Upscale" AllowDrop="True" DragOver="OnSuperDropCardDragOver" DragLeave="OnSuperDropCardDragLeave" Drop="OnSuperDropCardDrop" PointerEntered="OnSuperDropCardPointerEntered" PointerExited="OnSuperDropCardPointerExited">
                            <Grid>
                                <Border Background="{ThemeResource AccentFillColorDefaultBrush}" Opacity="0" CornerRadius="16"/>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="16">
                                    <FontIcon Glyph="&#xECE9;" Style="{StaticResource SuperDropCardIconStyle}"/>
                                    <TextBlock x:Name="TxtSuperDropUpscale" Style="{StaticResource SuperDropCardTextStyle}" Text=""/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource SuperDropCardStyle}" Tag="Effects" AllowDrop="True" DragOver="OnSuperDropCardDragOver" DragLeave="OnSuperDropCardDragLeave" Drop="OnSuperDropCardDrop" PointerEntered="OnSuperDropCardPointerEntered" PointerExited="OnSuperDropCardPointerExited">
                            <Grid>
                                <Border Background="{ThemeResource AccentFillColorDefaultBrush}" Opacity="0" CornerRadius="16"/>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="16">
                                    <FontIcon Glyph="&#xEB3C;" Style="{StaticResource SuperDropCardIconStyle}"/>
                                    <TextBlock x:Name="TxtSuperDropEffects" Style="{StaticResource SuperDropCardTextStyle}" Text=""/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border Grid.Row="2" Grid.Column="2" Style="{StaticResource SuperDropCardStyle}" Tag="Inspect" AllowDrop="True" DragOver="OnSuperDropCardDragOver" DragLeave="OnSuperDropCardDragLeave" Drop="OnSuperDropCardDrop" PointerEntered="OnSuperDropCardPointerEntered" PointerExited="OnSuperDropCardPointerExited">
                            <Grid>
                                <Border Background="{ThemeResource AccentFillColorDefaultBrush}" Opacity="0" CornerRadius="16"/>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="16">
                                    <FontIcon Glyph="&#xE71E;" Style="{StaticResource SuperDropCardIconStyle}"/>
                                    <TextBlock x:Name="TxtSuperDropInspect" Style="{StaticResource SuperDropCardTextStyle}" Text=""/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Viewbox>
            </Grid>
        </Grid>
    </Grid>

</Window>
